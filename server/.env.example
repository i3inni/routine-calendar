# 이 파일을 복사해 .env 로 만들고 값을 채우세요 (.env 는 커밋 금지).
# application.yml 이 ${ENV:기본값} 형태로 읽으므로, 운영에선 아래 값을 반드시 주입한다.
#
# 셸에서 주입 예시:
#   export $(grep -v '^#' .env | xargs) && ./gradlew bootRun

# ── DB ──
DB_URL=jdbc:postgresql://localhost:5432/routine_calendar
DB_USERNAME=routine
DB_PASSWORD=change-me

# ── JWT (운영에선 길고 무작위한 값으로!) ──
JWT_SECRET=please-generate-a-long-random-256bit-secret
JWT_ACCESS_VALIDITY=3600
JWT_REFRESH_VALIDITY=2592000

# ── 개발용 로그인 (운영=false) ──
DEV_LOGIN_ENABLED=true

# ── APNs (.p8 토큰 인증) ──
APNS_ENABLED=false
APNS_SANDBOX=true
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.yourteam.routinecalendar
# .p8 PEM 내용 전체 (개행 포함). 파일을 직접 두지 말고 환경변수로 주입.
APNS_PRIVATE_KEY=
